{
  "name": "Marginalia",
  "colorSpace": "oklch",
  "theme": "light",
  "accent": { "family": "clay", "hue": 41, "maxChroma": 0.106, "note": "terracotta/clay, well under 80% saturation" },
  "vars": {
    "--accent": "oklch(0.55 0.106 41)",
    "--scale": "1",
    "--density": "1",
    "--motion-mult": "1",

    "--clay-50": "oklch(0.962 0.012 45)",
    "--clay-100": "oklch(0.922 0.024 45)",
    "--clay-200": "oklch(0.860 0.040 44)",
    "--clay-300": "oklch(0.782 0.060 43)",
    "--clay-400": "oklch(0.700 0.084 42)",
    "--clay-500": "oklch(0.620 0.102 42)",
    "--clay-600": "oklch(0.550 0.106 41)",
    "--clay-700": "oklch(0.470 0.094 40)",
    "--clay-800": "oklch(0.390 0.075 39)",
    "--clay-900": "oklch(0.310 0.055 38)",

    "--paper-50": "oklch(0.987 0.006 60)",
    "--paper-100": "oklch(0.968 0.008 58)",
    "--paper-200": "oklch(0.936 0.009 56)",
    "--paper-300": "oklch(0.884 0.010 54)",
    "--paper-400": "oklch(0.782 0.011 52)",
    "--ink-500": "oklch(0.620 0.012 50)",
    "--ink-600": "oklch(0.500 0.013 48)",
    "--ink-700": "oklch(0.400 0.014 46)",
    "--ink-800": "oklch(0.320 0.014 44)",
    "--ink-900": "oklch(0.240 0.014 42)",

    "--signal-success": "oklch(0.520 0.072 145)",
    "--signal-success-soft": "oklch(0.940 0.022 145)",
    "--signal-error": "oklch(0.510 0.140 28)",
    "--signal-error-soft": "oklch(0.946 0.026 30)",
    "--signal-warning": "oklch(0.500 0.100 68)",
    "--signal-warning-soft": "oklch(0.948 0.030 78)",

    "--font-display": "\"Newsreader\", Georgia, serif",
    "--font-body": "\"Cabin\", system-ui, sans-serif",
    "--step--1": "0.833rem",
    "--step-0": "1.0rem",
    "--step-1": "1.25rem",
    "--step-2": "1.563rem",
    "--step-3": "1.953rem",
    "--step-4": "2.441rem",
    "--step-5": "3.052rem",
    "--space-1": "0.375rem",
    "--space-2": "0.625rem",
    "--space-3": "1.0rem",
    "--space-4": "1.5rem",
    "--space-5": "2.25rem",
    "--space-6": "3.5rem",
    "--radius-sm": "5px",
    "--radius-md": "9px",
    "--radius-lg": "16px",

    "--color-bg": "var(--paper-50)",
    "--color-surface": "var(--paper-100)",
    "--color-surface-2": "var(--paper-200)",
    "--color-accent": "var(--accent)",
    "--color-accent-strong": "var(--clay-700)",
    "--color-accent-soft": "var(--clay-100)",
    "--text-heading": "var(--ink-900)",
    "--text-body": "var(--ink-700)",
    "--text-muted": "var(--ink-600)",
    "--text-on-accent": "var(--paper-50)",
    "--border": "var(--paper-300)",
    "--border-strong": "var(--ink-500)",
    "--link": "var(--clay-700)",
    "--focus-ring": "var(--clay-600)",

    "--btn-bg": "var(--color-accent-strong, oklch(0.47 0.094 40))",
    "--btn-fg": "var(--text-on-accent, oklch(0.987 0.006 60))",
    "--btn-bg-hover": "var(--clay-800, oklch(0.39 0.075 39))",
    "--input-bg": "var(--color-bg, #fcfbf8)",
    "--input-border": "var(--border-strong, oklch(0.50 0.013 48))",
    "--card-bg": "var(--color-surface, #fcfbf8)",
    "--card-border": "var(--border, oklch(0.88 0.010 54))"
  },
  "layers": {
    "identity": {
      "clay": ["--clay-50","--clay-100","--clay-200","--clay-300","--clay-400","--clay-500","--clay-600","--clay-700","--clay-800","--clay-900"],
      "neutrals": ["--paper-50","--paper-100","--paper-200","--paper-300","--paper-400","--ink-500","--ink-600","--ink-700","--ink-800","--ink-900"],
      "signals": ["--signal-success","--signal-success-soft","--signal-error","--signal-error-soft","--signal-warning","--signal-warning-soft"],
      "type": ["--font-display","--font-body","--step--1","--step-0","--step-1","--step-2","--step-3","--step-4","--step-5"],
      "space": ["--space-1","--space-2","--space-3","--space-4","--space-5","--space-6","--radius-sm","--radius-md","--radius-lg"],
      "note": "The only layer that holds literal values. Colour is OKLCH; accent chroma <= 0.106 (well under 80% sat); neutrals share the clay hue (~42-60) at near-zero chroma."
    },
    "structure": {
      "color": ["--color-bg","--color-surface","--color-surface-2","--color-accent","--color-accent-strong","--color-accent-soft","--text-heading","--text-body","--text-muted","--text-on-accent","--border","--border-strong","--link","--focus-ring"],
      "note": "Semantic roles that reference identity. One accent family carried at 60-30-10 weight."
    },
    "with-fallback": {
      "tokens": ["--btn-bg","--btn-fg","--btn-bg-hover","--input-bg","--input-border","--card-bg","--card-border"],
      "note": "Component/usage tokens each carry a CSS fallback, so a missing token degrades gracefully instead of rendering an unstyled control."
    },
    "slot-alias": {
      "modes": {
        "light": "the :root default above",
        "dark": {
          "--color-bg": "oklch(0.205 0.012 44)",
          "--color-surface": "oklch(0.248 0.013 44)",
          "--color-surface-2": "oklch(0.300 0.014 44)",
          "--accent": "oklch(0.700 0.098 44)",
          "--color-accent-strong": "oklch(0.760 0.092 46)",
          "--color-accent-soft": "oklch(0.330 0.040 42)",
          "--text-heading": "oklch(0.948 0.010 60)",
          "--text-body": "oklch(0.880 0.011 56)",
          "--text-muted": "oklch(0.720 0.012 52)",
          "--text-on-accent": "oklch(0.210 0.014 44)",
          "--border": "oklch(0.360 0.013 46)",
          "--border-strong": "oklch(0.560 0.014 48)",
          "--link": "oklch(0.770 0.090 46)",
          "--focus-ring": "oklch(0.740 0.098 44)",
          "--signal-success": "oklch(0.820 0.100 150)",
          "--signal-success-soft": "oklch(0.320 0.040 145)",
          "--signal-error": "oklch(0.800 0.110 32)",
          "--signal-error-soft": "oklch(0.330 0.055 30)",
          "--signal-warning": "oklch(0.830 0.100 80)",
          "--signal-warning-soft": "oklch(0.330 0.050 78)"
        }
      },
      "note": "Light/dark re-point the structure layer via [data-mode]; never a parallel palette. Light is primary; dark is provided so the fourth layer is real."
    }
  }
}
