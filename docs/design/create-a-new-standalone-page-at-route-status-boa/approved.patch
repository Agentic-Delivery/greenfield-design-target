+import React from 'react'
+import { createRoot } from 'react-dom/client'
+import { StatusBoard } from './StatusBoard.jsx'
+
+// Status Board's OWN entry, served at /status-board/ in dev (web/status-board/index.html).
+// Mirrors the multi-entry pattern used by tide-now (web/src/main.jsx) and Saltmarsh
+// (web/src/saltmarsh/main.jsx): each route owns its HTML entry + mount.
+createRoot(document.getElementById('root')).render(
+  <React.StrictMode>
+    <StatusBoard />
+  </React.StrictMode>
+)
