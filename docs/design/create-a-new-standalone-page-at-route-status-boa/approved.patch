+++ b/web/src/status-board/status-board.css
@@ -0,0 +1,124 @@
+@import '../styles/tokens.css';
+
+* { box-sizing: border-box; margin: 0; padding: 0; }
+
+body {
+  background: var(--paper);
+  color: var(--ink);
+  font-family: "Barlow", system-ui, sans-serif;
+  font-size: calc(17px * var(--scale));
+  line-height: 1.45;
+  -webkit-font-smoothing: antialiased;
+  text-rendering: optimizeLegibility;
+  padding: max(env(safe-area-inset-top), 0px) 0 calc(40px * var(--density));
+}
+
+/* ── Layout (mobile-first, same column width as the tide-now app) ── */
+.sb {
+  max-width: 480px;
+  margin: 0 auto;
+  padding: var(--pad);
+  display: flex;
+  flex-direction: column;
+  gap: var(--gap);
+}
+
+/* ── Typography helpers (shared with app.css) ── */
+.sb .num {
+  font-family: "Saira", sans-serif;
+  font-weight: 700;
+  font-feature-settings: "tnum" 1;
+  font-variant-numeric: tabular-nums;
+}
+.sb-label {
+  font-family: "Saira", sans-serif;
+  text-transform: uppercase;
+  letter-spacing: 0.12em;
+  font-weight: 700;
+  font-size: calc(12px * var(--scale));
+  color: var(--ink-soft);
+  margin-top: 4px;
+}
+
+/* ── Header ── */
+.sb-header {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  gap: 12px;
+  border-bottom: 3px solid var(--line);
+  padding-bottom: calc(12px * var(--density));
+}
+.sb-wordmark {
+  font-family: "Saira", sans-serif;
+  font-weight: 800;
+  font-size: calc(20px * var(--scale));
+  letter-spacing: -0.01em;
+  text-transform: lowercase;
+}
+.sb-wordmark b { color: var(--accent-ink); }
+.sb-summary {
+  text-align: right;
+  font-family: "Saira", sans-serif;
+  font-weight: 600;
+  font-size: calc(14px * var(--scale));
+  color: var(--ink-soft);
+  text-transform: uppercase;
+  letter-spacing: 0.04em;
+  white-space: nowrap;
+}
+.sb-summary .num { font-size: calc(15px * var(--scale)); color: var(--ink); }
+.sb-summary-sep { margin: 0 6px; color: var(--line-soft); }
+
+/* ── Service cards ── */
+.sb-list {
+  list-style: none;
+  display: flex;
+  flex-direction: column;
+  gap: calc(10px * var(--density));
+}
+.sb-card {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  gap: 12px;
+  background: var(--surface);
+  border: 2.5px solid var(--line);
+  border-radius: var(--radius);
+  padding: calc(15px * var(--density)) calc(16px * var(--density));
+  min-height: 60px;
+}
+.sb-name {
+  font-family: "Saira", sans-serif;
+  font-weight: 700;
+  font-size: calc(18px * var(--scale));
+  letter-spacing: 0.005em;
+}
+
+/* ── Status pill — icon + word + colour, never colour alone ── */
+.sb-pill {
+  display: inline-flex;
+  align-items: center;
+  gap: 7px;
+  font-family: "Saira", sans-serif;
+  font-weight: 800;
+  text-transform: uppercase;
+  letter-spacing: 0.05em;
+  font-size: calc(13px * var(--scale));
+  padding: 6px 11px;
+  border-radius: var(--radius);
+  border: 2px solid currentColor;
+  white-space: nowrap;
+}
+.sb-pill--online { color: var(--safe); background: var(--safe-bg); }
+.sb-pill--offline { color: var(--danger); background: var(--danger-bg); }
+.sb-pill svg { display: block; }
+
+/* ── Responsive ── */
+@media (min-width: 768px) {
+  .sb { padding: calc(var(--pad) * 1.5); }
+}
+@media (min-width: 1024px) {
+  body { padding-top: calc(24px * var(--density)); }
+  .sb { max-width: 540px; }
+}
