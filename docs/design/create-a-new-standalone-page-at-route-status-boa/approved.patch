@@ -0,0 +1,71 @@
+import React from 'react'
+import './status-board.css'
+
+// Three demo services for the status board. `online: false` renders the offline pill.
+const SERVICES = [
+  { id: 'api-gateway', name: 'API Gateway', online: true },
+  { id: 'payments', name: 'Payments Service', online: true },
+  { id: 'object-storage', name: 'Object Storage', online: false },
+]
+
+const OnlineIcon = (
+  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="3" strokeLinecap="round" strokeLinejoin="round" aria-hidden="true">
+    <path d="M20 6 9 17l-5-5" />
+  </svg>
+)
+
+const OfflineIcon = (
+  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="3" strokeLinecap="round" strokeLinejoin="round" aria-hidden="true">
+    <path d="M18 6 6 18M6 6l12 12" />
+  </svg>
+)
+
+/**
+ * A status pill for one service. Status is conveyed by icon + word + colour —
+ * never colour alone (matches the app's accessibility rule for crossing status).
+ */
+function StatusPill({ online }) {
+  const state = online ? 'online' : 'offline'
+  return (
+    <span className={`sb-pill sb-pill--${state}`} role="status" aria-label={online ? 'Online' : 'Offline'}>
+      {online ? OnlineIcon : OfflineIcon}
+      {online ? 'Online' : 'Offline'}
+    </span>
+  )
+}
+
+/**
+ * Status Board — a simple, clean board of demo services, each with a name and an
+ * online/offline pill. Inherits the tide-now design system (tokens.css):
+ * Saira/Barlow, heavy ink borders, flat surfaces, functional safe/danger colours.
+ */
+export function StatusBoard() {
+  const onlineCount = SERVICES.filter((s) => s.online).length
+  const offlineCount = SERVICES.length - onlineCount
+
+  return (
+    <div className="sb">
+      <header className="sb-header">
+        <div className="sb-wordmark" aria-label="status board">
+          status<b>·</b>board
+        </div>
+        <div className="sb-summary" aria-label={`${onlineCount} online, ${offlineCount} offline`}>
+          <span className="num">{onlineCount}</span> online
+          <span className="sb-summary-sep" aria-hidden="true">·</span>
+          <span className="num">{offlineCount}</span> offline
+        </div>
+      </header>
+
+      <div className="sb-label">Services</div>
+
+      <ul className="sb-list">
+        {SERVICES.map((service) => (
+          <li key={service.id} className="sb-card">
+            <span className="sb-name">{service.name}</span>
+            <StatusPill online={service.online} />
+          </li>
+        ))}
+      </ul>
+    </div>
+  )
+}
