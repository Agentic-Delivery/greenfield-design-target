    Token contract mirrors docs/design/brand/tokens.json so the canvas
    tweaks panel (--accent, --scale, --density, --motion-mult, data-mode) is live.
 
-   Scoped to .mg-hero (NOT :root): --accent/--scale/--density/--motion-mult are
-   token names the tide app also owns in tokens.css. Both stylesheets stay loaded
-   in <head> for the page lifetime, so a global :root here would let Marginalia's
-   clay --accent permanently override the tide app's own amber once <App/> mounts
-   (e.g. TideHero's .trend badge). Scoping to the hero root keeps these tokens on
-   the landing screen only — every .mg-hero__* descendant still inherits them, so
-   the hero renders identically. */
+   Scoped to the landing screen (.mg-landing / .mg-hero), NOT :root:
+   --accent/--scale/--density/--motion-mult are token names the tide app also owns
+   in tokens.css. Both stylesheets stay loaded in <head> for the page lifetime, so a
+   global :root here would let Marginalia's clay --accent permanently override the
+   tide app's own amber once <App/> mounts (e.g. TideHero's .trend badge). Scoping to
+   the landing root keeps these tokens on the landing screen only — the hero and the
+   below-fold sections inherit them, and both selectors declare the block directly so
+   the scoping test still reads clay straight off .mg-hero (no inheritance reliance). */
+/* The token contract is declared on BOTH the landing wrapper and the hero as two
+   SINGLE-selector rules with identical bodies — deliberately NOT one `.mg-landing,
+   .mg-hero` comma list. The #35 scoping guard reads --accent straight off .mg-hero,
+   and the test DOM engine mis-cascades a comma list of these class selectors onto
+   :root (leaking the clay accent globally). Two single rules keep the hero's own
+   declaration exactly as the guard expects while extending the same tokens to the
+   below-fold sections via the wrapper. Both blocks must stay in sync. */
+.mg-landing {
+  /* live-tunable hooks */
+  --accent: oklch(0.55 0.106 41);
+  --scale: 1;
+  --density: 1;
+  --motion-mult: 1;
+
+  /* identity — clay ramp */
+  --clay-100: oklch(0.922 0.024 45);
+  --clay-600: oklch(0.550 0.106 41);
+  --clay-700: oklch(0.470 0.094 40);
+  --clay-800: oklch(0.390 0.075 39);
+
+  /* identity — paper / ink neutrals (warm-tinted to the clay hue) */
+  --paper-50: oklch(0.987 0.006 60);
+  --paper-100: oklch(0.968 0.008 58);
+  --paper-300: oklch(0.884 0.010 54);
+  --ink-600: oklch(0.500 0.013 48);
+  --ink-700: oklch(0.400 0.014 46);
+  --ink-900: oklch(0.240 0.014 42);
+
+  /* type */
+  --font-display: "Newsreader", Georgia, serif;
+  --font-body: "Cabin", system-ui, sans-serif;
+  --step-0: 1rem;
+  --step-1: 1.25rem;
+  --step-5: 3.052rem;
+
+  /* space / radius */
+  --space-3: 1rem;
+  --space-4: 1.5rem;
+  --space-5: 2.25rem;
+  --space-6: 3.5rem;
+  --radius-md: 9px;
+
+  /* structure — semantic roles referencing identity */
+  --color-bg: var(--paper-50);
+  --color-surface: var(--paper-100);
+  --color-accent: var(--accent);
+  --color-accent-strong: var(--clay-700);
+  --color-accent-soft: var(--clay-100);
+  --text-heading: var(--ink-900);
+  --text-body: var(--ink-700);
+  --text-muted: var(--ink-600);
+  --text-on-accent: var(--paper-50);
+  --border: var(--paper-300);
+  --focus-ring: var(--clay-600);
+
+  /* with-fallback — component tokens */
+  --btn-bg: var(--color-accent-strong, oklch(0.47 0.094 40));
+  --btn-fg: var(--text-on-accent, oklch(0.987 0.006 60));
+  --btn-bg-hover: var(--clay-800, oklch(0.39 0.075 39));
+}
 .mg-hero {
   /* live-tunable hooks */
   --accent: oklch(0.55 0.106 41);
