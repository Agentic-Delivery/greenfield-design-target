 }
 
+.mg-landing,
+.mg-landing *,
 .mg-hero,
 .mg-hero * { box-sizing: border-box; margin: 0; padding: 0; }
 
+/* Landing page container — carries the paper ground and body type for the hero
+   AND the below-fold sections. The hero keeps its own one-screen grid below. */
+.mg-landing {
+  background: var(--color-bg);
+  color: var(--text-body);
+  font-family: var(--font-body);
+  font-size: calc(17px * var(--scale));
+  line-height: 1.5;
+  -webkit-font-smoothing: antialiased;
+  text-rendering: optimizeLegibility;
+}
+
 /* One screen: a calm, centred landing that breathes. */
 .mg-hero {
   min-height: 100dvh;
@@ -204,6 +296,143 @@ html[data-mode="dark"] .mg-hero {
 }
 .mg-hero__foot svg { color: var(--color-accent); }
 
+/* ── Below-fold sections ─────────────────────────────────────────────────────
+   Same clay/paper/ink brand as the hero. The hero fills the first screen (100dvh);
+   these flow beneath it, quiet and editorial — no boxed cards, hierarchy from type
+   and whitespace. */
+
+.mg-section {
+  padding-block: calc(var(--space-6) * var(--density));
+  padding-inline: clamp(1.25rem, 6vw, 3rem);
+}
+
+/* Shared section eyebrow — mirrors the hero eyebrow's small-caps + clay hairline. */
+.mg-eyebrow {
+  font-family: var(--font-body);
+  font-size: 0.8rem;
+  font-weight: 600;
+  letter-spacing: 0.14em;
+  text-transform: uppercase;
+  color: var(--text-muted);
+  display: inline-flex;
+  align-items: center;
+  gap: 0.55em;
+}
+.mg-eyebrow::before {
+  content: "";
+  inline-size: 1.75rem;
+  block-size: 1px;
+  background: var(--color-accent);
+}
+
+.mg-section__title {
+  font-family: var(--font-display);
+  font-weight: 500;
+  font-size: clamp(1.7rem, 4.5vw, 2.25rem);
+  line-height: 1.15;
+  letter-spacing: -0.012em;
+  color: var(--text-heading);
+  text-wrap: balance;
+  margin-block-start: 0.6rem;
+  max-width: 22ch;
+}
+
+/* How it works — three editorial step columns, each under a thin clay-adjacent
+   rule (not a card). */
+.mg-steps {
+  max-width: 64rem;
+  margin-inline: auto;
+}
+.mg-steps__head {
+  margin-block-end: calc(var(--space-5) * var(--density));
+}
+.mg-steps__list {
+  list-style: none;
+  display: grid;
+  grid-template-columns: repeat(3, 1fr);
+  gap: clamp(1.5rem, 4vw, 3rem);
+}
+.mg-step {
+  display: flex;
+  flex-direction: column;
+  gap: 0.5rem;
+  padding-block-start: 1.1rem;
+  border-block-start: 1px solid var(--border);
+}
+.mg-step__num {
+  font-family: var(--font-display);
+  font-size: 1.3rem;
+  font-weight: 500;
+  font-variant-numeric: tabular-nums;
+  letter-spacing: 0.02em;
+  color: var(--color-accent);
+}
+.mg-step__title {
+  font-family: var(--font-display);
+  font-weight: 500;
+  font-size: 1.3rem;
+  line-height: 1.2;
+  color: var(--text-heading);
+}
+.mg-step__body {
+  font-size: 0.98rem;
+  line-height: 1.55;
+  color: var(--text-body);
+  max-width: 32ch;
+  text-wrap: pretty;
+}
+
+/* Testimonial — a single centred pull-quote from a named local ferry captain. */
+.mg-quote {
+  max-width: 46rem;
+  margin-inline: auto;
+  text-align: center;
+  display: flex;
+  flex-direction: column;
+  align-items: center;
+  gap: var(--space-4);
+}
+.mg-quote__mark {
+  font-family: var(--font-display);
+  font-size: 4rem;
+  line-height: 0.5;
+  color: var(--color-accent-soft);
+  block-size: 1.6rem;
+}
+.mg-quote__text {
+  font-family: var(--font-display);
+  font-style: italic;
+  font-weight: 400;
+  font-size: clamp(1.35rem, 3.4vw, 1.85rem);
+  line-height: 1.4;
+  color: var(--text-heading);
+  text-wrap: pretty;
+}
+.mg-quote__cite {
+  display: flex;
+  flex-direction: column;
+  gap: 0.2rem;
+}
+.mg-quote__name {
+  font-family: var(--font-body);
+  font-weight: 600;
+  font-size: 0.95rem;
+  letter-spacing: 0.02em;
+  color: var(--text-heading);
+}
+.mg-quote__role {
+  font-family: var(--font-body);
+  font-size: 0.8rem;
+  font-weight: 500;
+  letter-spacing: 0.09em;
+  text-transform: uppercase;
+  color: var(--text-muted);
+}
+
+@media (max-width: 640px) {
+  .mg-steps__list { grid-template-columns: 1fr; }
+}
+
 @media (prefers-reduced-motion: reduce) {
   .mg-hero__cta,
   .mg-hero__cta svg { transition: none; }
