diff --git a/web/src/saltmarsh/saltmarsh.css b/web/src/saltmarsh/saltmarsh.css
new file mode 100644
index 0000000..37fd3f9
--- /dev/null
+++ b/web/src/saltmarsh/saltmarsh.css
@@ -0,0 +1,270 @@
+@import url('https://fonts.googleapis.com/css2?family=Spectral:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Hanken+Grotesk:wght@400;500;600;700&display=swap');
+
+/* ----------------------------------------------------------------------------
+   Saltmarsh — small-batch coffee roaster
+   Design foundation: warm · crafted · calm. Light theme, warm cream paper,
+   espresso ink, one clay accent carried at ~10% weight (60-30-10).
+   Tokens are OKLCH so the live tweaks panel (--accent/--scale/--density/
+   --motion-mult/data-mode) repaints legibly.
+---------------------------------------------------------------------------- */
+
+:root {
+  --sm-hue: 52;
+
+  --paper: oklch(0.955 0.022 74);       /* warm cream, cosier — the 60 */
+  --surface: oklch(0.982 0.013 78);     /* lifted warm white */
+  --ink: oklch(0.26 0.03 50);           /* deep espresso — the 30, never #000 */
+  --ink-soft: oklch(0.38 0.022 52);     /* muted espresso, AA body on cream (incl. the cream card) */
+  --accent: oklch(0.58 0.11 42);        /* clay — the 10, decorative use */
+  --accent-ink: oklch(0.43 0.12 44);    /* clay for text, AA on cream */
+  --accent-wash: oklch(0.93 0.035 60);  /* soft warm backdrop for the product panel */
+  --line-soft: oklch(0.87 0.012 70);    /* hairline, tinted warm */
+  --cream: oklch(0.975 0.012 82);       /* button text on espresso */
+  --copy-card: oklch(0.93 0.024 80);    /* warm cream card behind the copy (≈ #f0e9dd) */
+
+  /* tweaks-panel knobs */
+  --scale: 1;
+  --density: 1;
+  --motion-mult: 1;
+
+  --radius: 16px;
+  --ease-out: cubic-bezier(0.16, 1, 0.3, 1);
+}
+
+/* Calm warm dark variant so the light/dark tweak has somewhere honest to go */
+[data-mode='dark'] {
+  --paper: oklch(0.23 0.018 52);
+  --surface: oklch(0.27 0.02 54);
+  --ink: oklch(0.94 0.014 82);
+  --ink-soft: oklch(0.80 0.016 78);
+  --accent: oklch(0.70 0.11 50);
+  --accent-ink: oklch(0.80 0.10 58);
+  --accent-wash: oklch(0.32 0.04 55);
+  --line-soft: oklch(0.40 0.02 56);
+  --cream: oklch(0.20 0.02 52);
+  --copy-card: oklch(0.27 0.022 54);
+}
+
+* { box-sizing: border-box; }
+
+.sm-page {
+  margin: 0;
+  min-height: 100dvh;
+  background: var(--paper);
+  color: var(--ink);
+  font-family: 'Hanken Grotesk', system-ui, -apple-system, sans-serif;
+  -webkit-font-smoothing: antialiased;
+  overflow-x: hidden;
+}
+
+/* slim masthead — identity only, keeps the hero in context */
+.sm-mast {
+  max-width: 1180px;
+  margin: 0 auto;
+  padding: clamp(1.25rem, 3vw, 2rem) clamp(1.25rem, 5vw, 3rem) 0;
+  display: flex;
+  align-items: center;
+  gap: 0.55rem;
+}
+.sm-mark {
+  font-family: 'Spectral', Georgia, serif;
+  font-weight: 500;
+  font-size: calc(1.35rem * var(--scale));
+  letter-spacing: -0.01em;
+  color: var(--ink);
+}
+.sm-mark-dot {
+  width: 9px; height: 9px; border-radius: 50%;
+  background: var(--accent); display: inline-block;
+  margin-left: 1px;
+}
+
+/* hero grid */
+.sm-hero {
+  max-width: 1180px;
+  margin: 0 auto;
+  padding: calc(clamp(2.25rem, 6vw, 4.5rem) * var(--density)) clamp(1.25rem, 5vw, 3rem)
+           calc(clamp(2.75rem, 7vw, 5.5rem) * var(--density));
+  display: grid;
+  grid-template-columns: 1fr;
+  gap: clamp(2.25rem, 5vw, 3.5rem);
+  align-items: center;
+}
+@media (min-width: 860px) {
+  .sm-hero {
+    grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
+    gap: clamp(2.5rem, 5vw, 5rem);
+  }
+}
+
+/* ---- copy column ---- */
+.sm-copy {
+  background: var(--copy-card);
+  color: var(--ink);
+  text-align: start;
+  font-size: calc(1rem * var(--scale));
+  font-weight: 400;
+  border: 1px solid var(--line-soft);
+  border-radius: 20px;
+  padding:
+    calc(clamp(2.25rem, 4vw, 3.36rem) * var(--density))
+    clamp(1.5rem, 4vw, 2.8rem)
+    calc(clamp(2.5rem, 4.5vw, 3.92rem) * var(--density));
+}
+
+.sm-eyebrow {
+  display: inline-flex;
+  align-items: center;
+  gap: 0.7em;
+  margin: 0 0 1.3rem;
+  font-size: calc(0.78rem * var(--scale));
+  font-weight: 600;
+  letter-spacing: 0.18em;
+  text-transform: uppercase;
+  color: var(--accent-ink);
+}
+.sm-eyebrow::before {
+  content: '';
+  width: 1.9rem; height: 2px;
+  background: var(--accent);
+  border-radius: 2px;
+}
+
+.sm-title {
+  margin: 0 0 1.4rem;
+  max-width: 15ch;
+  font-family: 'Spectral', Georgia, serif;
+  font-weight: 600;
+  font-size: calc(clamp(2.95rem, 6.6vw, 5rem) * var(--scale));
+  line-height: 1.01;
+  letter-spacing: -0.02em;
+  color: var(--ink);
+  overflow-wrap: break-word;
+}
+.sm-title em {
+  font-style: italic;
+  font-weight: 600;
+  color: var(--accent-ink);
+}
+
+.sm-sub {
+  margin: 0 0 2.1rem;
+  max-width: 46ch;
+  font-size: calc(clamp(1.02rem, 1.5vw, 1.2rem) * var(--scale));
+  line-height: 1.65;
+  color: var(--ink-soft);
+}
+
+.sm-actions {
+  display: flex;
+  align-items: center;
+  flex-wrap: wrap;
+  gap: 1.25rem;
+}
+
+.sm-cta {
+  display: inline-flex;
+  align-items: center;
+  gap: 0.6em;
+  padding: 0.95em 1.7em;
+  font-family: inherit;
+  font-size: calc(1rem * var(--scale));
+  font-weight: 600;
+  color: var(--cream);
+  background: var(--ink);
+  border: none;
+  border-radius: 999px;
+  text-decoration: none;
+  cursor: pointer;
+  box-shadow: 0 1px 2px oklch(0.26 0.03 50 / 0.18);
+  transition:
+    transform calc(170ms * var(--motion-mult)) var(--ease-out),
+    background-color calc(170ms * var(--motion-mult)) var(--ease-out),
+    box-shadow calc(170ms * var(--motion-mult)) var(--ease-out);
+}
+.sm-cta:hover {
+  transform: translateY(-2px);
+  background: oklch(0.32 0.055 46);
+  box-shadow: 0 10px 24px -8px oklch(0.26 0.03 50 / 0.34);
+}
+.sm-cta:active { transform: translateY(0); }
+.sm-cta:focus-visible {
+  outline: 3px solid var(--accent);
+  outline-offset: 3px;
+}
+.sm-cta svg {
+  transition: transform calc(170ms * var(--motion-mult)) var(--ease-out);
+}
+.sm-cta:hover svg { transform: translateX(3px); }
+
+.sm-reassure {
+  font-size: calc(0.9rem * var(--scale));
+  color: var(--ink-soft);
+}
+.sm-reassure b { color: var(--ink); font-weight: 600; }
+
+/* ---- product figure ---- */
+.sm-figure {
+  position: relative;
+  width: 100%;
+  max-width: 460px;
+  margin-inline: auto;
+  aspect-ratio: 5 / 5.4;
+  border-radius: var(--radius);
+  background: radial-gradient(125% 120% at 72% 18%, var(--accent-wash), var(--surface) 70%);
+  box-shadow: 0 30px 70px -34px oklch(0.26 0.03 50 / 0.32);
+  display: grid;
+  place-items: center;
+  padding: clamp(1.25rem, 4vw, 2.5rem);
+  overflow: hidden;
+}
+.sm-figure svg { width: 100%; height: 100%; }
+
+.sm-tag {
+  position: absolute;
+  left: clamp(0.9rem, 3vw, 1.4rem);
+  bottom: clamp(0.9rem, 3vw, 1.4rem);
+  display: inline-flex;
+  align-items: center;
+  gap: 0.5em;
+  padding: 0.5em 0.85em;
+  background: var(--surface);
+  border: 1px solid var(--line-soft);
+  border-radius: 999px;
+  font-size: calc(0.8rem * var(--scale));
+  font-weight: 600;
+  color: var(--ink);
+  box-shadow: 0 6px 16px -8px oklch(0.26 0.03 50 / 0.25);
+}
+.sm-tag .sm-tag-dot {
+  width: 8px; height: 8px; border-radius: 50%;
+  background: var(--accent);
+}
+
+/* svg part fills (theme-aware) */
+.sm-bag-label { fill: var(--surface); }
+.sm-bag-ink { fill: var(--ink); }
+.sm-bag-soft { fill: var(--ink-soft); }
+.sm-bag-accent { fill: var(--accent); }
+.sm-bag-line { stroke: var(--line-soft); }
+
+/* ---- first-load reveal (transform/opacity only, ease-out) ---- */
+.sm-reveal {
+  opacity: 0;
+  transform: translateY(14px);
+  animation: sm-rise calc(440ms * var(--motion-mult)) var(--ease-out) both;
+}
+.sm-reveal-1 { animation-delay: 40ms; }
+.sm-reveal-2 { animation-delay: 110ms; }
+.sm-reveal-3 { animation-delay: 180ms; }
+.sm-reveal-4 { animation-delay: 250ms; }
+.sm-reveal-5 { animation-delay: 200ms; }
+
+@keyframes sm-rise {
+  to { opacity: 1; transform: none; }
+}
+
+@media (prefers-reduced-motion: reduce) {
+  .sm-reveal { animation: none; opacity: 1; transform: none; }
+  .sm-cta, .sm-cta svg { transition: none; }
+}
