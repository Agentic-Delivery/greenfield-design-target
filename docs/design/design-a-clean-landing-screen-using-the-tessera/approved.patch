+import { defineConfig } from 'vite'
+import react from '@vitejs/plugin-react'
+import { fileURLToPath } from 'node:url'
+
+// Dedicated build for the Tessera landing — a SEPARATE product from tide-now,
+// published at its own GitHub Pages subpath (/tessera/). It needs its own --base,
+// which differs from tide-now's, so it MUST be a separate Vite build (Vite's base
+// is per-build). Mirrors how tide-now, Foxglove, and Saltmarsh are each staged
+// into their own subpath on the one unified Pages deploy.
+// Entry: web/tessera.html -> web/src/tessera/main.jsx (mounts TesseraLanding).
+export default defineConfig({
+  plugins: [react()],
+  build: {
+    outDir: 'dist-tessera',
+    emptyOutDir: true,
+    rollupOptions: {
+      input: fileURLToPath(new URL('./tessera.html', import.meta.url)),
+    },
+  },
+})
