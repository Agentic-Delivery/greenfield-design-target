+import React from 'react'
+import { createRoot } from 'react-dom/client'
+import { TesseraLanding } from './TesseraLanding.jsx'
+
+// Tessera's OWN entry. A SEPARATE build from tide-now (web/src/main.jsx mounts
+// <App />) and from the Saltmarsh hero — each product owns its entry and its own
+// Pages subpath. Entry: web/tessera.html -> this file -> <TesseraLanding />.
+createRoot(document.getElementById('root')).render(
+  <React.StrictMode>
+    <TesseraLanding />
+  </React.StrictMode>
+)
