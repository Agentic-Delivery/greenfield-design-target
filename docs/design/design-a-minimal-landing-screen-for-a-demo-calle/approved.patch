+import { MoatProof } from './MoatProof.jsx'
+import './moatproof.css'
+
+// MoatProof's OWN entry. This is a SEPARATE build from tide-now (web/src/main.jsx,
+// which still mounts <App />) and is published at its own subpath /moatproof/.
+// The design session's preview swap of tide-now's mount is intentionally NOT
+// shipped — each product owns its entry (mirrors src/saltmarsh/main.jsx).
+createRoot(document.getElementById('root')).render(
+  <React.StrictMode>
+    <MoatProof />
+  </React.StrictMode>
+)
