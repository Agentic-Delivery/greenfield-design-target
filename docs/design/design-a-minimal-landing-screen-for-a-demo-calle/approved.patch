diff --git a/web/vite.moatproof.config.js b/web/vite.moatproof.config.js
new file mode 100644
index 0000000..c4c81f5
--- /dev/null
+++ b/web/vite.moatproof.config.js
@@ -0,0 +1,19 @@
+import { defineConfig } from 'vite'
+import react from '@vitejs/plugin-react'
+import { fileURLToPath } from 'node:url'
+
+// Dedicated build for the MoatProof landing — a SEPARATE product from tide-now,
+// published at its own subpath (/moatproof/). It needs its own --base and entry,
+// so it MUST be a separate Vite build (Vite's base is per-build). This mirrors how
+// tide-now, Foxglove, and Saltmarsh are each staged into their own subpath.
+// Entry: web/moatproof.html -> web/src/moatproof/main.jsx (mounts MoatProof).
+export default defineConfig({
+  plugins: [react()],
+  build: {
+    outDir: 'dist-moatproof',
+    emptyOutDir: true,
+    rollupOptions: {
+      input: fileURLToPath(new URL('./moatproof.html', import.meta.url)),
+    },
+  },
+})
